# Cloud deploy (Render / Railway). Build from project root:
#   docker build -f Dockerfile.cloud -t india-portfolio-risk-lab .
FROM python:3.12-slim

WORKDIR /app
COPY deploy/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY deploy/server.py .
COPY deploy/static ./static
COPY portfolio.json /app/data/portfolio.json

ENV JET_DATA_DIR=/app/data
ENV PYTHONPATH=/app
EXPOSE 8000

CMD ["sh", "-c", "uvicorn server:app --host 0.0.0.0 --port ${PORT:-8000}"]
